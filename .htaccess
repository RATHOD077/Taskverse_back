# ENVIRONMENT VARIABLES
# Note: On some servers, you must set these in the cPanel 'Setup Node.js App' section instead.
<IfModule mod_env.c>
    SetEnv DB_HOST localhost
    SetEnv DB_USER admin_taskverse
    SetEnv DB_PASSWORD India@2026#               
    SetEnv DB_NAME taskverse_db
    SetEnv DB_PORT 3306
    SetEnv PORT 5000
    SetEnv JWT_SECRET tasksarsnkg,mfnfvajdngkjnbskjnfdkjfnkjvnfjakdngkjkjdzkfjfvkjkjgjvkjad
    SetEnv SMTP_HOST smtp.gmail.com
    SetEnv SMTP_PORT 465
    SetEnv SMTP_USER support@jaigajanan.in
    SetEnv SMTP_PASS India@2026#
    SetEnv CHECK_USERS_TABLE_EXISTENCE true
</IfModule>

# Handle Favicon and other static assets
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Handle Preflight OPTIONS requests
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ - [R=204,L]

    # If the file doesn't exist, let Passenger (Node.js) handle it
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ server.js [QSA,L]
</IfModule>

# CORS Headers for Apache (Dynamic Origin)
SetEnvIf Origin "^http(s)?://(crm\.digitalarchives\.co|localhost:5173)$" AccessControlAllowOrigin=$0
Header always set Access-Control-Allow-Origin %{AccessControlAllowOrigin}e env=AccessControlAllowOrigin
Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
Header always set Access-Control-Allow-Credentials "true"

